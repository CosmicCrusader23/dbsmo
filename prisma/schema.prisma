generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  TEACHER
  CONTENT_EDITOR
  ANALYST
  ADMIN
}

enum ExportJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ExportJobType {
  ATTEMPTS_CSV
  STUDENTS_CSV
  BACKUP_JSON
}

enum ProblemSetStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnswerType {
  EXACT
  INTEGER
  DECIMAL
  FRACTION
  SET
  MULTIPLE
  EXPRESSION
}

enum ProblemContentFormat {
  LATEX
  HTML
}

enum FeedbackType {
  WRONG_ANSWER_KEY
  WRONG_SOLUTION
  TYPO
  UNCLEAR
  OTHER
}

enum FeedbackStatus {
  OPEN
  REVIEWING
  RESOLVED
  REJECTED
}

enum FtwMatchStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum FtwRoomStatus {
  LOBBY
  IN_PROGRESS
  COMPLETED
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  name                  String?
  emailVerified         DateTime?
  image                 String?
  displayName           String?
  avatarUrl             String?
  role                  UserRole             @default(STUDENT)
  group                 String?
  profileVisible        Boolean              @default(true)
  leaderboardVisible    Boolean              @default(true)
  theme                 String               @default("light")
  greetingSettings      String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  lastLoginAt           DateTime?
  attempts              Attempt[]
  feedbackReports       FeedbackReport[]
  uploadedFiles         ImportedFile[]
  createdProblemSets    ProblemSet[]         @relation("ProblemSetCreator")
  problemSetBookmarks   ProblemSetBookmark[]
  writeups              Writeup[]
  writeupVotes          WriteupVote[]
  accounts              Account[]
  sessions              Session[]
  sentFriendships       Friendship[]         @relation("FriendshipRequester")
  receivedFriendships   Friendship[]         @relation("FriendshipReceiver")
  practiceSolves        PracticeSolve[]
  auditLogs             AuditLog[]           @relation("AuditLogActor")
  exportJobs            ExportJob[]          @relation("ExportJobRequester")
  ftwMatches            FtwMatch[]
  hostedFtwRooms        FtwRoom[]            @relation("FtwRoomHost")
  ftwRoomPlayers        FtwRoomPlayer[]
  ftwRoomAnswers        FtwRoomAnswer[]
  teachingClasses       Class[]              @relation("ClassTeacher")
  classMemberships      ClassMember[]        @relation("ClassMembership")
  authoredAssignments   Assignment[]         @relation("AssignmentAuthor")
  authoredAnnouncements Announcement[]       @relation("AnnouncementAuthor")
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  receiverId  String
  createdAt   DateTime @default(now())
  requester   User     @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User     @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([receiverId])
}

model ProblemSet {
  id             String               @id @default(cuid())
  slug           String               @unique
  title          String
  description    String               @default("")
  order          String               @default("")
  status         ProblemSetStatus     @default(DRAFT)
  visibleFrom    DateTime?
  visibleTo      DateTime?
  allowedGroups  String[]
  topicTags      String[]
  difficulty     Int                  @default(1)
  videoUrl       String?
  problemFileId  String?
  solutionFileId String?
  createdById    String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  attempts       Attempt[]
  feedback       FeedbackReport[]
  problems       Problem[]
  bookmarks      ProblemSetBookmark[]
  assets         ProblemSetAsset[]
  writeups       Writeup[]
  createdBy      User                 @relation("ProblemSetCreator", fields: [createdById], references: [id])
  problemFile    ImportedFile?        @relation("ProblemFile", fields: [problemFileId], references: [id])
  solutionFile   ImportedFile?        @relation("SolutionFile", fields: [solutionFileId], references: [id])
  assignments    Assignment[]
}

model ProblemSetAsset {
  id           String       @id @default(cuid())
  problemSetId String
  key          String
  fileId       String
  createdAt    DateTime     @default(now())
  problemSet   ProblemSet   @relation(fields: [problemSetId], references: [id], onDelete: Cascade)
  file         ImportedFile @relation("AssetFile", fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([problemSetId, key])
  @@index([fileId])
}

model ProblemSetBookmark {
  id           String     @id @default(cuid())
  userId       String
  problemSetId String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemSet   ProblemSet @relation(fields: [problemSetId], references: [id], onDelete: Cascade)

  @@unique([userId, problemSetId])
  @@index([problemSetId])
}

model Problem {
  id              String               @id @default(cuid())
  problemSetId    String
  number          Int
  statement       String               @default("")
  contentFormat   ProblemContentFormat @default(LATEX)
  answerKey       String
  answerType      AnswerType
  acceptedAnswers String[]
  caseSensitive   Boolean              @default(false)
  explanationNote String?
  topicTags       String[]
  points          Int                  @default(1)
  problemSet      ProblemSet           @relation(fields: [problemSetId], references: [id], onDelete: Cascade)
  responses       Response[]
  feedbackReports FeedbackReport[]
  practiceSolves  PracticeSolve[]
  ftwAnswers      FtwAnswer[]
  ftwRoomProblems FtwRoomProblem[]

  @@unique([problemSetId, number])
}

model PracticeSolve {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId])
  @@index([problemId])
}

model Attempt {
  id              String     @id @default(cuid())
  userId          String
  problemSetId    String
  attemptNumber   Int
  score           Int
  maxScore        Int
  submittedAt     DateTime   @default(now())
  durationSeconds Int?
  gradedAt        DateTime   @default(now())
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemSet      ProblemSet @relation(fields: [problemSetId], references: [id], onDelete: Cascade)
  responses       Response[]

  @@unique([userId, problemSetId, attemptNumber])
  @@index([userId])
  @@index([problemSetId])
  @@index([submittedAt])
}

model Response {
  id               String  @id @default(cuid())
  attemptId        String
  problemId        String
  rawAnswer        String
  normalizedAnswer String
  isCorrect        Boolean
  pointsAwarded    Int
  graderNote       String?
  attempt          Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  problem          Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([attemptId, problemId])
  @@index([problemId])
}

model FeedbackReport {
  id           String         @id @default(cuid())
  userId       String
  problemSetId String
  problemId    String?
  type         FeedbackType
  message      String
  status       FeedbackStatus @default(OPEN)
  adminNote    String?
  createdAt    DateTime       @default(now())
  resolvedAt   DateTime?
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemSet   ProblemSet     @relation(fields: [problemSetId], references: [id], onDelete: Cascade)
  problem      Problem?       @relation(fields: [problemId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([problemSetId])
}

model ImportedFile {
  id              String            @id @default(cuid())
  storageKey      String            @unique
  originalName    String
  mimeType        String
  sizeBytes       Int
  checksum        String
  uploadedById    String
  createdAt       DateTime          @default(now())
  uploadedBy      User              @relation(fields: [uploadedById], references: [id])
  problemFileFor  ProblemSet[]      @relation("ProblemFile")
  solutionFileFor ProblemSet[]      @relation("SolutionFile")
  assetFor        ProblemSetAsset[] @relation("AssetFile")
  writeupImageFor WriteupImage[]    @relation("WriteupImageFile")
}

model Writeup {
  id            String               @id @default(cuid())
  problemSetId  String
  authorId      String
  title         String
  body          String
  contentFormat ProblemContentFormat @default(LATEX)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  problemSet    ProblemSet           @relation(fields: [problemSetId], references: [id], onDelete: Cascade)
  author        User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images        WriteupImage[]
  votes         WriteupVote[]

  @@index([problemSetId, createdAt])
  @@index([authorId, createdAt])
}

model WriteupImage {
  id        String       @id @default(cuid())
  writeupId String
  fileId    String
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  writeup   Writeup      @relation(fields: [writeupId], references: [id], onDelete: Cascade)
  file      ImportedFile @relation("WriteupImageFile", fields: [fileId], references: [id], onDelete: Cascade)

  @@index([writeupId, sortOrder])
  @@index([fileId])
}

model WriteupVote {
  id        String   @id @default(cuid())
  writeupId String
  userId    String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  writeup   Writeup  @relation(fields: [writeupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([writeupId, userId])
  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model ExportJob {
  id            String          @id @default(cuid())
  type          ExportJobType
  status        ExportJobStatus @default(PENDING)
  requestedById String
  fileName      String?
  mimeType      String?
  payload       Json?
  error         String?
  createdAt     DateTime        @default(now())
  completedAt   DateTime?
  requestedBy   User            @relation("ExportJobRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([requestedById, createdAt])
  @@index([status, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FtwMatch {
  id             String         @id @default(cuid())
  userId         String
  tag            String?
  status         FtwMatchStatus @default(IN_PROGRESS)
  totalProblems  Int            @default(10)
  problemsServed Int            @default(0)
  totalScore     Int            @default(0)
  maxScore       Int            @default(60)
  startedAt      DateTime       @default(now())
  completedAt    DateTime?
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers        FtwAnswer[]

  @@index([userId, startedAt])
  @@index([status, totalScore])
}

model FtwAnswer {
  id           String    @id @default(cuid())
  matchId      String
  problemId    String
  problemIndex Int
  servedAt     DateTime  @default(now())
  submittedAt  DateTime?
  rawAnswer    String?
  isCorrect    Boolean?
  elapsedMs    Int?
  points       Int       @default(0)
  match        FtwMatch  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  problem      Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([matchId, problemIndex])
  @@index([matchId])
}

model FtwRoom {
  id             String           @id @default(cuid())
  code           String           @unique
  hostId         String
  tag            String?
  status         FtwRoomStatus    @default(LOBBY)
  totalProblems  Int              @default(10)
  problemLimitMs Int              @default(45000)
  currentIndex   Int              @default(-1)
  createdAt      DateTime         @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  host           User             @relation("FtwRoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  players        FtwRoomPlayer[]
  problems       FtwRoomProblem[]

  @@index([status, createdAt])
}

model FtwRoomPlayer {
  id       String          @id @default(cuid())
  roomId   String
  userId   String
  score    Int             @default(0)
  joinedAt DateTime        @default(now())
  leftAt   DateTime?
  room     FtwRoom         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers  FtwRoomAnswer[]

  @@unique([roomId, userId])
  @@index([userId])
}

model FtwRoomProblem {
  id           String          @id @default(cuid())
  roomId       String
  problemId    String
  problemIndex Int
  servedAt     DateTime        @default(now())
  endsAt       DateTime
  lockedAt     DateTime?
  room         FtwRoom         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  problem      Problem         @relation(fields: [problemId], references: [id], onDelete: Cascade)
  answers      FtwRoomAnswer[]

  @@unique([roomId, problemIndex])
  @@index([roomId])
}

model FtwRoomAnswer {
  id            String         @id @default(cuid())
  roomProblemId String
  playerId      String
  userId        String
  rawAnswer     String?
  submittedAt   DateTime?
  elapsedMs     Int?
  isCorrect     Boolean?
  points        Int            @default(0)
  roomProblem   FtwRoomProblem @relation(fields: [roomProblemId], references: [id], onDelete: Cascade)
  player        FtwRoomPlayer  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomProblemId, userId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Class {
  id            String         @id @default(cuid())
  name          String
  teacherId     String
  teacher       User           @relation("ClassTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  members       ClassMember[]
  assignments   Assignment[]
  announcements Announcement[]
  createdAt     DateTime       @default(now())

  @@index([teacherId])
}

model ClassMember {
  classId   String
  studentId String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User     @relation("ClassMembership", fields: [studentId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@id([classId, studentId])
  @@index([studentId])
}

model Assignment {
  id           String     @id @default(cuid())
  classId      String
  problemSetId String
  assignedById String
  dueAt        DateTime?
  createdAt    DateTime   @default(now())
  class        Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  problemSet   ProblemSet @relation(fields: [problemSetId], references: [id], onDelete: Cascade)
  assignedBy   User       @relation("AssignmentAuthor", fields: [assignedById], references: [id])

  @@unique([classId, problemSetId])
  @@index([classId])
  @@index([problemSetId])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation("AnnouncementAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  classes     Class[]

  @@index([createdById, createdAt])
}
