DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dbsmo?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
SCHOOL_EMAIL_DOMAINS="g.dbs.edu.hk,dbs.edu.hk"
# Local development only. The bypass is disabled unless this is exactly "true",
# and it is always disabled when NODE_ENV=production.
AUTH_DEV_BYPASS="false"
STORAGE_DRIVER="local"
LOCAL_STORAGE_ROOT="./storage"
# Optional lower caps; hard maximums remain 5 MB JSON and 50 MB legacy ZIP.
MAX_JSON_UPLOAD_MB="5"
MAX_ZIP_UPLOAD_MB="50"
