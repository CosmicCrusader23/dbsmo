    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "js-yaml": "5.2.1",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "lucide-react": "1.12.0",
    "next": "16.2.10",
    "next-auth": "4.24.14",
